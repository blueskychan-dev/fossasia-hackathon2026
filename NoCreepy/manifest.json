{
  "manifest_version": 3,
  "name": "NoCreepy Discord Safety",
  "version": "1.0",
  "description": "Blocks dangerous servers and censors creepy messages on Discord.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.discord.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.discord.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}